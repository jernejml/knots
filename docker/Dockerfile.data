# Data-preprocessing image: board partitions, board overlays, dataset stats.
#
# Build (from repo root, so `scripts/` is in the build context):
#   docker build -f docker/Dockerfile.data -t knots-data .
#
# Run:
#   docker run --rm \
#     -v "$PWD/data:/work/data:ro" \
#     -v "$PWD/out:/work/out" \
#     knots-data python3 scripts/prepare.py

FROM python:3.13-slim

WORKDIR /work

RUN pip install --no-cache-dir \
        numpy==2.4.2 \
        scipy==1.17.1 \
        Pillow==11.3.0

COPY scripts/ ./scripts/
