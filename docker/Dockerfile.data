# Data-preprocessing image: dataset stats and per-frame analysis.
#
# Build (from repo root, so `scripts/` is in the build context):
#   docker build -f docker/Dockerfile.data -t knots-data .
#
# Run:
#   docker run --rm \
#     -v "$PWD/data:/work/data:ro" \
#     -v "$PWD/analysis:/work/analysis" \
#     knots-data python3 scripts/analyze_dataset.py
#
#   docker run --rm \
#     -v "$PWD/data:/work/data:ro" \
#     knots-data python3 scripts/dataset_stats.py --sort gaps --order desc

FROM python:3.13-slim

WORKDIR /work

RUN pip install --no-cache-dir \
    numpy==2.4.2 \
    scipy==1.17.1 \
    Pillow==11.3.0

COPY scripts/ ./scripts/
